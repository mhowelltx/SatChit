# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/satchit"

# AI Provider — one of: anthropic | openai | stub
AI_PROVIDER="stub"

# API keys (only the key for the chosen provider is required)
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""

# Server
PORT=3001
SESSION_SECRET="change-me-in-production"
JWT_SECRET="change-me-in-production"

# Rishi admin bootstrap (optional)
# If set, the server upserts this admin + Rishi avatar on every startup (idempotent).
# Leave blank to skip — you can create the account through the app later.
RISHI_USERNAME=""
RISHI_PASSWORD=""
RISHI_NAME=""    # Avatar display name (defaults to RISHI_USERNAME if blank)
RISHI_EMAIL=""   # Optional

# Web (Next.js)
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_WS_URL="http://localhost:3001"
