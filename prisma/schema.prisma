// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Users ─────────────────────────────────────────────────────────────────────

enum UserRole {
  PLAYER
  CREATOR
  ADMIN
}

model User {
  id           String   @id @default(cuid())
  email        String?  @unique
  username     String   @unique
  passwordHash String
  role         UserRole @default(PLAYER)
  createdAt    DateTime @default(now())

  profile         UserProfile?
  createdWorlds   World[]
  gameSessions    GameSession[]
  characters      Character[]
  discoveredZones VedaZone[]     @relation("ZoneDiscoverer")
  avatarCharacter AvatarCharacter?

  @@map("users")
}

model UserProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  bio       String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

// ── Worlds ────────────────────────────────────────────────────────────────────

enum WorldVisibility {
  PUBLIC
  PRIVATE
}

model World {
  id                  String          @id @default(cuid())
  creatorId           String
  name                String
  slug                String          @unique
  description         String
  visibility          WorldVisibility @default(PUBLIC)
  foundationalLaws    String[]
  culturalTypologies  String[]
  anthropicApiKey     String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  creator           User                   @relation(fields: [creatorId], references: [id])
  zones             VedaZone[]
  entities          VedaEntity[]
  events            VedaEvent[]
  lore              VedaLore[]
  sessions          GameSession[]
  characters        Character[]
  npcs              NPC[]
  items             Item[]
  characterTemplate WorldCharacterTemplate?

  @@map("worlds")
}

// AI-generated per-world character creation template
model WorldCharacterTemplate {
  id            String   @id @default(cuid())
  worldId       String   @unique
  templateJson  Json     // structured template: factions, customAttributes, stats, affinities, etc.
  generatedAt   DateTime @default(now())
  updatedAt     DateTime @updatedAt

  world World @relation(fields: [worldId], references: [id], onDelete: Cascade)

  @@map("world_character_templates")
}

// ── Veda ──────────────────────────────────────────────────────────────────────

// A location/zone players can explore
model VedaZone {
  id               String   @id @default(cuid())
  worldId          String
  name             String
  slug             String
  description      String
  rawContent       String   // Full AI-generated text stored verbatim
  discoveredById   String?
  ownerCharacterId String?  // Character who owns this location (home, etc.)
  discoveredAt     DateTime @default(now())

  world        World        @relation(fields: [worldId], references: [id], onDelete: Cascade)
  discoveredBy User?        @relation("ZoneDiscoverer", fields: [discoveredById], references: [id])
  owner        Character?   @relation("OwnedZones", fields: [ownerCharacterId], references: [id])
  entities     VedaEntity[]
  sessions     GameSession[]
  npcsHere     NPC[]

  @@unique([worldId, slug])
  @@map("veda_zones")
}

enum EntityType {
  NPC
  CREATURE
  FACTION
  OBJECT
}

// An entity encountered in the world (Veda's knowledge record)
model VedaEntity {
  id           String     @id @default(cuid())
  worldId      String
  zoneId       String?
  name         String
  entityType   EntityType
  description  String
  attributes   Json       @default("{}")
  discoveredAt DateTime   @default(now())

  world World     @relation(fields: [worldId], references: [id], onDelete: Cascade)
  zone  VedaZone? @relation(fields: [zoneId], references: [id])
  npc   NPC?

  @@map("veda_entities")
}

// A notable event that happened in the world
model VedaEvent {
  id             String   @id @default(cuid())
  worldId        String
  description    String
  participantIds String[]
  occurredAt     DateTime @default(now())

  world World @relation(fields: [worldId], references: [id], onDelete: Cascade)

  @@map("veda_events")
}

enum LoreCategory {
  LAW
  CULTURE
  COSMOLOGY
  MYTH
}

// Fundamental world lore: laws, cultures, cosmology, myths
model VedaLore {
  id        String       @id @default(cuid())
  worldId   String
  category  LoreCategory
  title     String
  content   String
  createdAt DateTime     @default(now())

  world World @relation(fields: [worldId], references: [id], onDelete: Cascade)

  @@map("veda_lore")
}

// ── Characters ────────────────────────────────────────────────────────────────

// A player's avatar within a specific world
model Character {
  id                  String   @id @default(cuid())
  userId              String
  worldId             String
  name                String
  species             String?
  race                String?
  gender              String?
  age                 Int?
  physicalDescription String?
  traits              String[] // Personality traits
  skills              Json     @default("{}") // skill -> level map
  abilities           String[]
  backstory           String?
  stats               Json     @default("{}") // health, mana, xp, etc.
  customAttributes    Json     @default("{}") // world-specific fields from WorldCharacterTemplate
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user      User            @relation(fields: [userId], references: [id])
  world     World           @relation(fields: [worldId], references: [id], onDelete: Cascade)
  inventory CharacterItem[]
  sessions  GameSession[]
  ownedZones VedaZone[]     @relation("OwnedZones")

  @@unique([userId, worldId, name])
  @@map("characters")
}

// ── NPCs ──────────────────────────────────────────────────────────────────────

// A persistent NPC generated through world exploration
model NPC {
  id                  String   @id @default(cuid())
  worldId             String
  vedaEntityId        String?  @unique // Link to Veda knowledge record
  currentZoneId       String?
  name                String
  species             String?
  race                String?
  gender              String?
  age                 Int?
  physicalDescription String?
  traits              String[]
  skills              Json     @default("{}")
  abilities           String[]
  backstory           String?
  disposition         String   @default("neutral") // friendly, neutral, hostile, wary, etc.
  stats               Json     @default("{}")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  world       World       @relation(fields: [worldId], references: [id], onDelete: Cascade)
  vedaEntity  VedaEntity? @relation(fields: [vedaEntityId], references: [id])
  currentZone VedaZone?   @relation(fields: [currentZoneId], references: [id])
  inventory   NPCItem[]

  @@map("npcs")
}

// ── Items ─────────────────────────────────────────────────────────────────────

model Item {
  id          String   @id @default(cuid())
  worldId     String
  name        String
  description String
  itemType    String   // weapon, armor, consumable, key, document, misc, etc.
  attributes  Json     @default("{}")
  createdAt   DateTime @default(now())

  world          World           @relation(fields: [worldId], references: [id], onDelete: Cascade)
  characterItems CharacterItem[]
  npcItems       NPCItem[]

  @@map("items")
}

// Character inventory entry
model CharacterItem {
  id          String  @id @default(cuid())
  characterId String
  itemId      String
  quantity    Int     @default(1)
  isEquipped  Boolean @default(false)

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  item      Item      @relation(fields: [itemId], references: [id])

  @@map("character_items")
}

// NPC inventory entry
model NPCItem {
  id       String @id @default(cuid())
  npcId    String
  itemId   String
  quantity Int    @default(1)

  npc  NPC  @relation(fields: [npcId], references: [id], onDelete: Cascade)
  item Item @relation(fields: [itemId], references: [id])

  @@map("npc_items")
}

// ── Rishi Avatar ──────────────────────────────────────────────────────────────

// A Rishi's cross-world avatar character (one per Rishi, not bound to any world)
model AvatarCharacter {
  id          String   @id @default(cuid())
  userId      String   @unique
  name        String
  description String?
  traits      String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("avatar_characters")
}

// ── Sessions ──────────────────────────────────────────────────────────────────

enum SessionStatus {
  ACTIVE
  ENDED
}

model GameSession {
  id            String        @id @default(cuid())
  worldId       String
  playerId      String
  characterId   String?
  currentZoneId String?
  status        SessionStatus @default(ACTIVE)
  startedAt     DateTime      @default(now())

  world       World       @relation(fields: [worldId], references: [id])
  player      User        @relation(fields: [playerId], references: [id])
  character   Character?  @relation(fields: [characterId], references: [id])
  currentZone VedaZone?   @relation(fields: [currentZoneId], references: [id])
  actions     PlayerAction[]

  @@map("game_sessions")
}

model PlayerAction {
  id          String   @id @default(cuid())
  sessionId   String
  rawInput    String
  aiResponse  String
  timestamp   DateTime @default(now())

  session GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("player_actions")
}
