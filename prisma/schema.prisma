// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Users ─────────────────────────────────────────────────────────────────────

enum UserRole {
  PLAYER
  CREATOR
  ADMIN
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String   @unique
  passwordHash String
  role         UserRole @default(PLAYER)
  createdAt    DateTime @default(now())

  createdWorlds  World[]
  gameSessions   GameSession[]
  discoveredZones VedaZone[]  @relation("ZoneDiscoverer")

  @@map("users")
}

// ── Worlds ────────────────────────────────────────────────────────────────────

enum WorldVisibility {
  PUBLIC
  PRIVATE
}

model World {
  id                  String          @id @default(cuid())
  creatorId           String
  name                String
  slug                String          @unique
  description         String
  visibility          WorldVisibility @default(PUBLIC)
  foundationalLaws    String[]
  culturalTypologies  String[]
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  creator      User          @relation(fields: [creatorId], references: [id])
  zones        VedaZone[]
  entities     VedaEntity[]
  events       VedaEvent[]
  lore         VedaLore[]
  sessions     GameSession[]

  @@map("worlds")
}

// ── Veda ──────────────────────────────────────────────────────────────────────

// A location/zone players can explore
model VedaZone {
  id             String   @id @default(cuid())
  worldId        String
  name           String
  slug           String
  description    String
  rawContent     String   // Full AI-generated text stored verbatim
  discoveredById String?
  discoveredAt   DateTime @default(now())

  world        World        @relation(fields: [worldId], references: [id], onDelete: Cascade)
  discoveredBy User?        @relation("ZoneDiscoverer", fields: [discoveredById], references: [id])
  entities     VedaEntity[]
  sessions     GameSession[]

  @@unique([worldId, slug])
  @@map("veda_zones")
}

enum EntityType {
  NPC
  CREATURE
  FACTION
  OBJECT
}

// An entity encountered in the world
model VedaEntity {
  id           String     @id @default(cuid())
  worldId      String
  zoneId       String?
  name         String
  entityType   EntityType
  description  String
  attributes   Json       @default("{}")
  discoveredAt DateTime   @default(now())

  world World     @relation(fields: [worldId], references: [id], onDelete: Cascade)
  zone  VedaZone? @relation(fields: [zoneId], references: [id])

  @@map("veda_entities")
}

// A notable event that happened in the world
model VedaEvent {
  id             String   @id @default(cuid())
  worldId        String
  description    String
  participantIds String[]
  occurredAt     DateTime @default(now())

  world World @relation(fields: [worldId], references: [id], onDelete: Cascade)

  @@map("veda_events")
}

enum LoreCategory {
  LAW
  CULTURE
  COSMOLOGY
  MYTH
}

// Fundamental world lore: laws, cultures, cosmology, myths
model VedaLore {
  id        String       @id @default(cuid())
  worldId   String
  category  LoreCategory
  title     String
  content   String
  createdAt DateTime     @default(now())

  world World @relation(fields: [worldId], references: [id], onDelete: Cascade)

  @@map("veda_lore")
}

// ── Sessions ──────────────────────────────────────────────────────────────────

enum SessionStatus {
  ACTIVE
  ENDED
}

model GameSession {
  id            String        @id @default(cuid())
  worldId       String
  playerId      String
  currentZoneId String?
  status        SessionStatus @default(ACTIVE)
  startedAt     DateTime      @default(now())

  world       World       @relation(fields: [worldId], references: [id])
  player      User        @relation(fields: [playerId], references: [id])
  currentZone VedaZone?   @relation(fields: [currentZoneId], references: [id])
  actions     PlayerAction[]

  @@map("game_sessions")
}

model PlayerAction {
  id          String   @id @default(cuid())
  sessionId   String
  rawInput    String
  aiResponse  String
  timestamp   DateTime @default(now())

  session GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("player_actions")
}
